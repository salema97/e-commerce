<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
  <cloud-backup>
    <!--
      Never back up expo-secure-store SharedPreferences to the cloud. The data
      is encrypted with the Android Keystore and cannot be restored on another
      device or account.
    -->
    <exclude domain="sharedpref" path="SecureStore" />
  </cloud-backup>
  <device-transfer>
    <exclude domain="sharedpref" path="SecureStore" />
  </device-transfer>
</data-extraction-rules>
