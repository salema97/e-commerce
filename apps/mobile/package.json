{
  "name": "@repo/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "description": "Expo React Native mobile app for the e-commerce platform",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "dev": "expo start --dev-client",
    "build": "expo export",
    "lint": "echo 'No lint configured'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo node_modules/.cache"
  },
  "dependencies": {
    "@repo/api-client": "workspace:^",
    "@repo/shared-config": "workspace:^",
    "@repo/shared-types": "workspace:^",
    "@repo/shared-ui": "workspace:^",
    "@repo/shared-utils": "workspace:^",
    "@stripe/stripe-react-native": "^0.42.0",
    "@tanstack/react-query": "catalog:",
    "expo": "56.0.12",
    "expo-constants": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "catalog:",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~3.0.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-worklets": "~0.9.2"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "babel-preset-expo": "~56.0.15",
    "typescript": "catalog:"
  }
}
