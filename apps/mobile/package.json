{
  "name": "@repo/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "description": "Expo React Native mobile app for the e-commerce platform",
  "scripts": {
    "start": "expo start",
    "start:android": "node scripts/ensure-android-emulator.mjs && expo start --android",
    "android": "node scripts/run-expo-android.mjs",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "dev": "expo start --dev-client",
    "dev:android": "node scripts/ensure-android-emulator.mjs && expo start --dev-client --android",
    "health:expo": "expo-doctor",
    "build": "expo export --platform android --platform ios",
    "lint": "echo 'No lint configured'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo node_modules/.cache"
  },
  "dependencies": {
    "@expo-google-fonts/anton": "0.4.2",
    "@expo-google-fonts/space-grotesk": "0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@repo/api-client": "workspace:^",
    "@repo/shared-config": "workspace:^",
    "@repo/shared-types": "workspace:^",
    "@repo/shared-ui": "workspace:^",
    "@repo/shared-utils": "workspace:^",
    "@sentry/react-native": "7.11.0",
    "@stripe/stripe-react-native": "^0.64.0",
    "@tanstack/react-query": "catalog:",
    "expo": "56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-font": "56.0.7",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "catalog:",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-worklets": "~0.8.3"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "babel-preset-expo": "~56.0.15",
    "expo-doctor": "1.19.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "typescript"
      ]
    }
  }
}
