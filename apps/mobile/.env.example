# API (must match apps/api — use EXPO_PUBLIC_API_URL only)
# Physical device / iOS simulator on same machine:
EXPO_PUBLIC_API_URL=http://localhost:3001/v1
# Android emulator (localhost inside emulator ≠ your PC — use 10.0.2.2):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/v1

# Android emulator auto-start (scripts/ensure-android-emulator.mjs)
# ANDROID_HOME=D:\Development\Android
# ANDROID_AVD=Android
# SKIP_ANDROID_EMULATOR=1

# Optional: Stripe publishable key for checkout
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
