# Public API base URL used by the browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/v1

# Server-side API base URL (RSC / Server Actions)
API_BASE_URL=http://localhost:3001/v1

# Product media CDN (optional — enables next/image for S3 URLs)
# AWS_S3_PUBLIC_URL=https://s3.example.com/e-commerce

# Public base URL for SEO metadata (canonical URLs, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Native auth (must match API AUTH_JWT_ACCESS_SECRET)
AUTH_JWT_ACCESS_SECRET=dev-access-secret-change-me-32chars-min

# Dev login after `pnpm --filter @repo/api prisma:seed`:
# store-admin@example.com / SeedDemo123!  (ADMIN)
# cliente@example.com / SeedDemo123!      (CUSTOMER — loyalty 550 pts SILVER)
# support@example.com / SeedDemo123!      (SUPPORT)
# finance@example.com / SeedDemo123!      (FINANCE)
# Referral code (admin): STOREADMIN → checkout ?ref=STOREADMIN

# Stripe (publishable key is exposed to the browser; secret key stays server-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Product analytics (consent-aware)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=
