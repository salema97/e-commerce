# Public API base URL (browser analytics only — app traffic uses /api/v1 proxy)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/v1

# Server-side API base URL (RSC / Server Actions / auth routes)
API_BASE_URL=http://localhost:3001/v1

# Product media CDN (optional — enables next/image for S3 URLs)
# AWS_S3_PUBLIC_URL=https://s3.example.com/e-commerce

# Public site origin for SEO (canonical URLs, sitemap, robots)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Deployment tier (development | staging | production) — affects secure cookie flags
# APP_ENV=development

# Native auth (must match API AUTH_JWT_ACCESS_SECRET)
AUTH_JWT_ACCESS_SECRET=<generate-strong-secret>

# Dev login after `pnpm --filter @repo/api prisma:seed`:
# store-admin@example.com / $SEED_USER_PASSWORD  (ADMIN)
# cliente@example.com / $SEED_USER_PASSWORD      (CUSTOMER — loyalty 550 pts SILVER)
# support@example.com / $SEED_USER_PASSWORD      (SUPPORT)
# finance@example.com / $SEED_USER_PASSWORD      (FINANCE)
# Configure SEED_USER_PASSWORD in apps/api/.env (must be >= 32 chars in production).
# Referral code (admin): STOREADMIN → checkout ?ref=STOREADMIN

# Stripe publishable key (secret key stays in apps/api/.env only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<stripe-publishable-key>

# Product analytics (consent-aware)
NEXT_PUBLIC_POSTHOG_KEY=<posthog-key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=
