# Production overrides — copy to .env on production hosts
APP_ENV=production
NODE_ENV=production
PORT=3001

CORS_ORIGINS=https://tienda.example.com

# Production secrets via secret manager — never commit real values
# CLERK_SECRET_KEY=sk_live_...
# STRIPE_SECRET_KEY=sk_live_...

SRI_TEST_ENVIRONMENT=false
ENABLE_TEST_AUTH=false

SENTRY_TRACES_SAMPLE_RATE=0.1
EMAIL_PROVIDER=resend
PRODUCT_ANALYTICS_PROVIDER=posthog
WHATSAPP_NOTIFICATIONS_ENABLED=true
