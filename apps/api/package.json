{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "NestJS 11 REST API for the e-commerce platform",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "start:debug": "tsx watch --inspect src/main.ts",
    "start:prod": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'Lint not configured in Phase 1A'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:reset": "dotenv -e .env -- prisma migrate reset --force",
    "search:reindex": "dotenv -e .env -- tsx src/scripts/search-reindex.ts",
    "clean": "rm -rf dist .turbo"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.105.0",
    "@aws-sdk/client-s3": "3.1068.0",
    "@aws-sdk/s3-request-presigner": "3.1068.0",
    "@clerk/backend": "^1.27.0",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@repo/api-client": "workspace:^",
    "@repo/shared-config": "workspace:^",
    "@repo/shared-types": "workspace:^",
    "@repo/shared-utils": "workspace:^",
    "@sentry/node": "10.60.0",
    "@upstash/kafka": "1.3.5",
    "@xmldom/xmldom": "0.8.13",
    "bullmq": "^5.49.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "fast-xml-parser": "5.9.3",
    "helmet": "8.2.0",
    "ioredis": "5.11.1",
    "meilisearch": "0.58.0",
    "nestjs-pino": "4.6.1",
    "node-forge": "1.4.0",
    "openai": "6.44.0",
    "pdfkit": "0.18.0",
    "pg": "8.22.0",
    "pino-http": "11.0.0",
    "posthog-node": "5.38.3",
    "reflect-metadata": "0.2.2",
    "resend": "6.12.4",
    "rxjs": "7.8.1",
    "soap": "^1.1.0",
    "stripe": "^22.0.0",
    "xmldsigjs": "2.8.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@types/express": "5.0.6",
    "@types/node": "^22.13.0",
    "@types/node-forge": "^1.3.11",
    "@types/pdfkit": "0.17.6",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "dotenv": "17.4.2",
    "dotenv-cli": "11.0.0",
    "prisma": "7.8.0",
    "supertest": "7.2.2",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
