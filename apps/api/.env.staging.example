# Staging overrides — copy to .env on staging hosts
APP_ENV=staging
NODE_ENV=production
PORT=3001

CORS_ORIGINS=https://staging.example.com,https://staging-admin.example.com

# Staging Stripe test keys (configure via secret manager)
# STRIPE_SECRET_KEY=sk_test_...

SRI_TEST_ENVIRONMENT=true
ENABLE_TEST_AUTH=false

SENTRY_TRACES_SAMPLE_RATE=0.2
EMAIL_PROVIDER=resend
PRODUCT_ANALYTICS_PROVIDER=posthog
WHATSAPP_NOTIFICATIONS_ENABLED=true
