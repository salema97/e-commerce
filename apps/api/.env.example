# apps/api — canonical API environment (copy to .env)
# Web must share AUTH_JWT_ACCESS_SECRET (see apps/web/.env.example)

# Server
PORT=3001
NODE_ENV=development
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database & cache
DATABASE_URL=postgresql://postgres:<postgres-password>@localhost:5432/ecommerce
REDIS_URL=redis://localhost:6379
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECT_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=30000

# Search
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=<generate-strong-secret>

# Native auth (must match apps/web AUTH_JWT_ACCESS_SECRET — use same value in both .env files)
AUTH_JWT_ACCESS_SECRET=<generate-strong-secret>
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_DAYS=30
SEED_USER_PASSWORD=<generate-strong-secret>

# Payments
STRIPE_SECRET_KEY=<generate-strong-secret>
STRIPE_WEBHOOK_SECRET=<generate-strong-secret>
STRIPE_SUCCESS_URL=https://localhost:3000/checkout/success
STRIPE_CANCEL_URL=https://localhost:3000/checkout/cancel

# Local payment providers
KUSHKI_PRIVATE_KEY=<kushki-private-key>
KUSHKI_WEBHOOK_SECRET=<kushki-webhook-secret>
PAYPHONE_TOKEN=<payphone-token>
PAYPHONE_STORE_ID=<payphone-store-id>
MERCADOPAGO_ACCESS_TOKEN=<mercadopago-access-token>
MERCADOPAGO_WEBHOOK_SECRET=<mercadopago-webhook-secret>
PLACETOPAY_LOGIN=<placetopay-login>
PLACETOPAY_SECRET_KEY=<placetopay-secret-key>
PLACETOPAY_BASE_URL=https://checkout-test.placetopay.com

# Storage (AWS S3 / MinIO — preferred)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<generate-strong-secret>
AWS_SECRET_ACCESS_KEY=<generate-strong-secret>
AWS_S3_BUCKET=e-commerce
AWS_S3_ENDPOINT=https://s3.example.com
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_PUBLIC_URL=https://s3.example.com/e-commerce

# Messaging (Evolution API)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=<evolution-api-key>
EVOLUTION_WEBHOOK_SECRET=<generate-strong-secret>
EVOLUTION_INSTANCE_NAME=ecommerce
# Local Docker: configure Evolution webhook via POST /webhook/set/{instance}
# url=http://host.docker.internal:3001/v1/webhooks/evolution, byEvents=true,
# headers.x-webhook-secret must match EVOLUTION_WEBHOOK_SECRET
WHATSAPP_NOTIFICATIONS_ENABLED=true

# Notifications / ops
EMAIL_PROVIDER=console
RESEND_API_KEY=<resend-api-key>
TRANSACTIONAL_EMAIL_FROM=noreply@example.com
EMAIL_NOTIFICATIONS_ENABLED=true
PUSH_PROVIDER=console
EXPO_ACCESS_TOKEN=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
PUSH_NOTIFICATIONS_ENABLED=true
MARKETING_EMAIL_PROVIDER=console
LOOPS_API_KEY=
NOTIFICATION_UNSUBSCRIBE_SECRET=
STOREFRONT_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001/v1
ABANDONED_CART_ENABLED=true
ABANDONED_CART_REMINDER_HOURS=24
WIN_BACK_ENABLED=true
LLM_PROVIDER=console
EMBEDDING_PROVIDER=console
SUPPORT_BOT_ENABLED=false
SEMANTIC_SEARCH_ENABLED=auto
KNOWLEDGE_INDEX_QUEUE_ENABLED=true
KNOWLEDGE_USE_PGVECTOR=true
BOT_CONFIDENCE_THRESHOLD=0.7
POSTHOG_KEY=<posthog-key>
POSTHOG_HOST=https://us.i.posthog.com
PRODUCT_ANALYTICS_PROVIDER=console
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
EVENT_BUS_ENABLED=true
EVENT_BUS_BACKEND=redis

# Shipping, taxes & fulfillment (Phase 12)
SHIPPING_FREE_THRESHOLD=50
SHIPPING_FLAT_RATE=5
CARRIER_RATE_PROVIDER=zones
SHIPPO_API_KEY=
EASYPOST_API_KEY=
SHIPENGINE_API_KEY=
TAX_PROVIDER=composite
INTERNATIONAL_TAX_PROVIDER=stripe_tax
STRIPE_TAX_ENABLED=false
TAXJAR_API_KEY=
FULFILLMENT_PROVIDER=manual
WMS_WEBHOOK_SECRET=
ALLOW_BACKORDERS=false

# Phase 13 — Catalog cache
CATALOG_CACHE_TTL_SECONDS=120
MARKETING_PLACEMENT_CACHE_TTL_SECONDS=90

KAFKA_URL=
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_DOMAIN_EVENTS_TOPIC=domain-events

# SRI Ecuador e-invoicing (direct SOAP integration)
SRI_RUC=<sri-ruc>
SRI_DIGITAL_CERTIFICATE_PATH=/path/to/cert.p12
SRI_DIGITAL_CERTIFICATE_PASSWORD=<sri-digital-certificate-password>
SRI_ESTABLISHMENT_CODE=001
SRI_EMISSION_POINT_CODE=001
SRI_TEST_ENVIRONMENT=true
SRI_COMPANY_NAME=Comercio Demo
SRI_COMPANY_TRADE_NAME=Comercio Demo
SRI_COMPANY_ADDRESS=Quito, Ecuador
SRI_COMPANY_SPECIAL_TAXPAYER_NUMBER=536
SRI_COMPANY_REQUIRES_ACCOUNTING=true
SRI_QUEUE_ENABLED=true
SRI_WORKER_CONCURRENCY=5
SRI_MAX_RETRIES=5
SRI_RECONCILIATION_CRON=0 * * * *
SRI_DELIVERY_ENABLED=true
SRI_EMAIL_FROM=facturas@example.com

# Phase 15 — Marketplace, ERP/B2B
MARKETPLACE_CHANNEL=console
MERCADO_LIBRE_ACCESS_TOKEN=
MERCADO_LIBRE_SELLER_ID=
ACCOUNTING_PROVIDER=console
SIIGO_API_KEY=
SIIGO_API_URL=

# Bot protection (checkout)
CAPTCHA_PROVIDER=none
# CAPTCHA_PROVIDER=hcaptcha
# HCAPTCHA_SECRET_KEY=

# Optional — defaults in env.providers.schema.ts (uncomment to override)
# RETURN_WINDOW_DAYS=30
# DEFAULT_LOCAL_PAYMENT_PROVIDER=PLACETOPAY
# LOYALTY_SIGNUP_POINTS=25
# LOYALTY_REVIEW_POINTS=50
# LOYALTY_REFERRAL_POINTS=100
# LOYALTY_PURCHASE_POINTS_PER_DOLLAR=1
# LOYALTY_POINT_VALUE=0.01
# LOYALTY_POINTS_EXPIRATION_DAYS=365
# REFERRAL_COMMISSION_RATE=0.05
# EXTERNAL_REVIEW_PROVIDER=console
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# EMBEDDING_MODEL=text-embedding-3-small
# KNOWLEDGE_INDEX_QUEUE_CONCURRENCY=3
