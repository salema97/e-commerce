# Server
PORT=3001
NODE_ENV=development
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database & cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce
REDIS_URL=redis://localhost:6379

# Search
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=dev-master-key

# Native auth (must match apps/web AUTH_JWT_ACCESS_SECRET — use same value in both .env files)
AUTH_JWT_ACCESS_SECRET=dev-access-secret-change-me-32chars-min
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_DAYS=30
SEED_USER_PASSWORD=SeedDemo123!

# Payments
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=https://localhost:3000/checkout/success
STRIPE_CANCEL_URL=https://localhost:3000/checkout/cancel

# Local payment providers (dev placeholders)
KUSHKI_PRIVATE_KEY=dev-kushki-key
KUSHKI_WEBHOOK_SECRET=dev-kushki-webhook
PAYPHONE_TOKEN=dev-payphone-token
PAYPHONE_STORE_ID=dev-store-id
MERCADOPAGO_ACCESS_TOKEN=dev-mercadopago-token
MERCADOPAGO_WEBHOOK_SECRET=dev-mercadopago-webhook
PLACETOPAY_LOGIN=dev-placetopay-login
PLACETOPAY_SECRET_KEY=dev-placetopay-secret
PLACETOPAY_BASE_URL=https://checkout-test.placetopay.com

# Storage (AWS S3 / MinIO — preferred)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_S3_BUCKET=e-commerce
AWS_S3_ENDPOINT=https://s3.example.com
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_PUBLIC_URL=https://s3.example.com/e-commerce

# Messaging (Evolution API)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_WEBHOOK_SECRET=e2e-evolution-webhook-secret
EVOLUTION_INSTANCE_NAME=ecommerce
# Local Docker: configure Evolution webhook via POST /webhook/set/{instance}
# url=http://host.docker.internal:3001/v1/webhooks/evolution, byEvents=true,
# headers.x-webhook-secret must match EVOLUTION_WEBHOOK_SECRET
WHATSAPP_NOTIFICATIONS_ENABLED=true

# Notifications / ops
EMAIL_PROVIDER=console
RESEND_API_KEY=re_xxx
TRANSACTIONAL_EMAIL_FROM=noreply@example.com
EMAIL_NOTIFICATIONS_ENABLED=true
PUSH_PROVIDER=console
EXPO_ACCESS_TOKEN=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
PUSH_NOTIFICATIONS_ENABLED=true
MARKETING_EMAIL_PROVIDER=console
LOOPS_API_KEY=
STOREFRONT_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001/v1
ABANDONED_CART_ENABLED=true
ABANDONED_CART_REMINDER_HOURS=24
WIN_BACK_ENABLED=true
LLM_PROVIDER=console
EMBEDDING_PROVIDER=console
SUPPORT_BOT_ENABLED=true
SEMANTIC_SEARCH_ENABLED=auto
CONVERSATION_ORCHESTRATOR=native
KNOWLEDGE_INDEX_QUEUE_ENABLED=true
KNOWLEDGE_USE_PGVECTOR=true
BOT_CONFIDENCE_THRESHOLD=0.7
POSTHOG_KEY=phc_xxx
POSTHOG_HOST=https://us.i.posthog.com
PRODUCT_ANALYTICS_PROVIDER=console
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
EVENT_BUS_ENABLED=true
EVENT_BUS_BACKEND=redis

# Shipping, taxes & fulfillment (Phase 12)
SHIPPING_FREE_THRESHOLD=50
SHIPPING_FLAT_RATE=5
CARRIER_RATE_PROVIDER=zones
SHIPPO_API_KEY=
EASYPOST_API_KEY=
SHIPENGINE_API_KEY=
TAX_PROVIDER=composite
INTERNATIONAL_TAX_PROVIDER=stripe_tax
STRIPE_TAX_ENABLED=false
TAXJAR_API_KEY=
FULFILLMENT_PROVIDER=manual
WMS_PROVIDER=manual
WMS_WEBHOOK_SECRET=
ALLOW_BACKORDERS=false

# Phase 13 — Catalog cache
CATALOG_CACHE_TTL_SECONDS=120
MARKETING_PLACEMENT_CACHE_TTL_SECONDS=90

KAFKA_URL=
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_DOMAIN_EVENTS_TOPIC=domain-events

# SRI Ecuador e-invoicing (direct integration)
# Dev cert: pnpm --filter @repo/api sri:generate-dev-cert (gitignored under apps/api/certs/)
SRI_MODE=direct
SRI_RUC=0591764479001
SRI_SOL_KEY=dev-sol-key
SRI_DIGITAL_CERTIFICATE_PATH=certs/dev-sri.p12
SRI_DIGITAL_CERTIFICATE_PASSWORD=DevSriCert0591!
SRI_ESTABLISHMENT_CODE=001
SRI_EMISSION_POINT_CODE=001
SRI_TEST_ENVIRONMENT=true
SRI_COMPANY_NAME=Comercio Demo
SRI_COMPANY_TRADE_NAME=Comercio Demo
SRI_COMPANY_ADDRESS=Quito, Ecuador
SRI_COMPANY_SPECIAL_TAXPAYER_NUMBER=536
SRI_COMPANY_REQUIRES_ACCOUNTING=true
SRI_QUEUE_ENABLED=true
SRI_WORKER_CONCURRENCY=5
SRI_MAX_RETRIES=5
SRI_RECONCILIATION_CRON=0 * * * *
SRI_DELIVERY_ENABLED=true
SRI_EMAIL_FROM=facturas@example.com

# Phase 15 — Marketplace, ERP/B2B
MARKETPLACE_CHANNEL=console
MERCADO_LIBRE_ACCESS_TOKEN=
MERCADO_LIBRE_SELLER_ID=
ACCOUNTING_PROVIDER=console
SIIGO_API_KEY=
SIIGO_API_URL=
MULTI_CURRENCY_ENABLED=false

# Bot protection (checkout)
CAPTCHA_PROVIDER=none
# CAPTCHA_PROVIDER=hcaptcha
# HCAPTCHA_SECRET_KEY=
