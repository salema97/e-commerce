  date            DateTime     @default(now())
  relatedOrderId  String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  order Order? @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)

  @@index([source])
  @@index([date])
  @@index([createdAt])
  @@index([relatedOrderId])
}

model Expense {
  id          String        @id @default(uuid())
  categoryId  String?
  supplierId  String?
  amount      Decimal       @db.Decimal(12, 2)
  date        DateTime      @default(now())
  status      ExpenseStatus @default(PENDING)
  description String?
  attachments Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([supplierId])
  @@index([status])
  @@index([date])
  @@index([createdAt])
}

model ExpenseCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses Expense[]

  @@index([name])
}

model ReturnRequest {
  id               String        @id @default(uuid())
  orderId          String
  userId           String?
  status           ReturnStatus  @default(REQUESTED)
  reason           String
  refundMethod     RefundMethod?
  returnWindowDays Int           @default(30)
  inspectedAt      DateTime?
  resolvedAt       DateTime?
  closedAt         DateTime?
  approvedById     String?
  rejectedById     String?
  creditNoteId     String?       @unique
  exchangeOrderId  String?       @unique
  returnCarrier         String?
  returnTrackingNumber  String?
  returnTrackingUrl     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  order         Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  items         ReturnItem[]
  creditNote    CreditNote?  @relation(fields: [creditNoteId], references: [id], onDelete: SetNull)
  refunds       Refund[]
  exchangeOrder Order?       @relation("ExchangeOrder", fields: [exchangeOrderId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([exchangeOrderId])
}

model ReturnItem {
  id               String              @id @default(uuid())
  returnRequestId  String
  productId        String
  productVariantId String?
  quantity         Int
  condition        ReturnItemCondition?
  refundValue      Decimal?            @db.Decimal(12, 2)
  createdAt        DateTime            @default(now())

  returnRequest ReturnRequest     @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  product       Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant       ProductVariant?   @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([returnRequestId])
  @@index([productId])
  @@index([productVariantId])
}

model CreditNote {
  id                     String            @id @default(uuid())
  accessKey              String            @unique
  parentInvoiceAccessKey String?
  sequenceNumber         String?
  authorizationNumber    String?
  authorizationDate      DateTime?
  status                 CreditNoteStatus  @default(DRAFT)
  sriStatus              SriDocumentStatus @default(PENDING)
  signedXml              String?           @db.Text
  xmlKey                 String?
  pdfKey                 String?
  retryCount             Int               @default(0)
  lastError              String?
  sriResponse            Json?
  deliveryStatus         String?
  deliveredAt            DateTime?
  deliveryError          String?
  totalAmount            Decimal           @db.Decimal(12, 2)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  returnRequest ReturnRequest?

  @@index([accessKey])
  @@index([parentInvoiceAccessKey])
  @@index([status])
  @@index([sriStatus])
  @@index([createdAt])
}

model SriDocumentJob {
  id           String               @id @default(uuid())
  documentType String
  documentId   String
