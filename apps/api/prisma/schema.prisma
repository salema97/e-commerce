  orderId   String?
  expiresAt DateTime?
  createdAt DateTime               @default(now())

  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([type])
  @@index([expiresAt])
  @@index([createdAt])
}

model Company {
  id               String          @id @default(uuid())
  name             String
  taxId            String          @unique
  creditLimit      Decimal         @db.Decimal(12, 2) @default(0)
  creditUsed       Decimal         @db.Decimal(12, 2) @default(0)
  netPaymentTerms  NetPaymentTerms @default(NET_30)
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  users      CompanyUser[]
  priceLists CompanyPriceList[]
  quotes     Quote[]
  orders     Order[]

  @@index([isActive])
}

model CompanyUser {
  id        String          @id @default(uuid())
  companyId String
  userId    String
  role      CompanyUserRole @default(BUYER)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
}

model CompanyPriceList {
  id          String   @id @default(uuid())
  companyId   String
  productId   String
  variantId   String?
  unitPrice   Decimal  @db.Decimal(12, 2)
  minQuantity Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([companyId, productId, variantId])
  @@index([companyId])
  @@index([productId])
}

model Quote {
  id                  String      @id @default(uuid())
  quoteNumber         String      @unique
  companyId           String?
  requestedByUserId   String?
  status              QuoteStatus @default(DRAFT)
  expiresAt           DateTime
  purchaseOrderNumber String?
  subtotal            Decimal     @db.Decimal(12, 2) @default(0)
  taxAmount           Decimal     @db.Decimal(12, 2) @default(0)
  total               Decimal     @db.Decimal(12, 2) @default(0)
  notes               String?
  convertedOrderId    String?     @unique
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  company       Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  requestedBy   User?       @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  items         QuoteLine[]
  convertedOrder Order?     @relation(fields: [convertedOrderId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([expiresAt])
}

model QuoteLine {
  id        String   @id @default(uuid())
  quoteId   String
  productId String
  variantId String?
  name      String
  sku       String
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model MarketplaceListing {
  id           String                   @id @default(uuid())
  productId    String
  channel      MarketplaceChannel
  externalId   String?
  status       MarketplaceListingStatus @default(DRAFT)
  lastSyncedAt DateTime?
  lastError    String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, channel])
  @@index([channel])
  @@index([status])
}

model MarketplaceOrderImport {
  id              String                  @id @default(uuid())
  channel         MarketplaceChannel
  externalOrderId String
  orderId         String?                 @unique
  status          MarketplaceImportStatus @default(PENDING)
  fees            Decimal?                @db.Decimal(12, 2)
  payload         Json
  error           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([channel, externalOrderId])
  @@index([status])
}

model AccountingSyncRecord {
  id           String                 @id @default(uuid())
  provider     AccountingProviderType
  resourceType String
  resourceId   String
  externalId   String?
  status       AccountingSyncStatus   @default(PENDING)
  lastError    String?
  syncedAt     DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([provider, resourceType, resourceId])
  @@index([status])
}

model StoreLocation {
  id             String   @id @default(uuid())
  code           String   @unique
  name           String
  address        String
  city           String?
  province       String?
  phone          String?
  supportsPickup Boolean  @default(true)
  supportsPos    Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  registers PosRegister[]
  orders    Order[]

  @@index([isActive])
  @@index([supportsPickup])
  @@index([supportsPos])
}

model PosRegister {
  id           String   @id @default(uuid())
  locationId   String
  code         String
  name         String
  isActive     Boolean  @default(true)
  lastClosedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  location StoreLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@unique([locationId, code])
  @@index([locationId])
  @@index([isActive])
}

model SubscriptionPlan {
  id              String               @id @default(uuid())
  productId       String               @unique
  stripeProductId String?
  stripePriceId   String?
  interval        SubscriptionInterval @default(MONTHLY)
  intervalCount   Int                  @default(1)
  trialDays       Int                  @default(0)
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  product       Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscriptions CustomerSubscription[]

  @@index([isActive])
  @@index([interval])
}

model CustomerSubscription {
  id                   String             @id @default(uuid())
  userId               String
  planId               String
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([planId])
  @@index([status])
}

model Seller {
  id             String       @id @default(uuid())
  userId         String       @unique
  businessName   String
  slug           String       @unique
  commissionRate Decimal      @db.Decimal(5, 2) @default(15)
  status         SellerStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  orderItems OrderItem[]
  payouts  SellerPayout[]
  disputes MarketplaceDispute[]

  @@index([status])
  @@index([slug])
}

model SellerPayout {
  id               String             @id @default(uuid())
  sellerId         String
  orderId          String?
  grossAmount      Decimal            @db.Decimal(12, 2)
  commissionAmount Decimal            @db.Decimal(12, 2)
  netAmount        Decimal            @db.Decimal(12, 2)
  status           SellerPayoutStatus @default(PENDING)
  paidAt           DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([sellerId])
  @@index([orderId])
  @@index([status])
}

model MarketplaceDispute {
  id              String                   @id @default(uuid())
  orderId         String
  sellerId        String
  openedByUserId  String
  reason          String
  status          MarketplaceDisputeStatus @default(OPEN)
  resolutionNotes String?
  resolvedAt      DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seller   Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  openedBy User   @relation("DisputeOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([sellerId])
  @@index([status])
  @@index([openedByUserId])
}
