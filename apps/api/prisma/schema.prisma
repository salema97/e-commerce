generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FINANCE
  INVENTORY
  SUPPORT
  CUSTOMER
  GUEST
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderChannel {
  WEB
  MOBILE
  POS
}

enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  PAYMENT_FAILED
  PARTIALLY_REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  KUSHKI
  PAYPHONE
  MERCADOPAGO
  PLACETOPAY
  CASH
}

enum RefundStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  AUTHORIZED
  REJECTED
  FAILED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUNDLE
  TIERED
}

enum ConversationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IncomeSource {
  ORDER
  INVESTMENT
  OTHER
}

enum ExpenseStatus {
  PENDING
  PAID
  CANCELLED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  INSPECTION
  RESOLVED
  RESOLUTION_PENDING_CREDIT_NOTE
  CLOSED
}

enum ReturnItemCondition {
  NEW
  USED
  DAMAGED
}

enum RefundMethod {
  ORIGINAL_PAYMENT
  STORE_CREDIT
  EXCHANGE
}

enum CreditNoteStatus {
  DRAFT
  SUBMITTED
  AUTHORIZED
  REJECTED
  FAILED
}

model User {
  id               String    @id @default(uuid())
  clerkUserId      String    @unique
  email            String    @unique
  role             Role      @default(CUSTOMER)
  phone            String?
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  orders        Order[]
  carts         Cart[]
  wishlists     Wishlist[]
  addresses     Address[]
  conversations Conversation[]
  auditLogs     AuditLog[]
  returns       ReturnRequest[]
  storeCredits  StoreCredit[]

  @@index([clerkUserId])
  @@index([role])
  @@index([email])
  @@index([stripeCustomerId])
  @@index([createdAt])
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  products Product[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@index([createdAt])
}

model Product {
  id             String        @id @default(uuid())
  name           String
  slug           String        @unique
  description    String?
  sku            String?       @unique
  status         ProductStatus @default(DRAFT)
  price          Decimal       @db.Decimal(12, 2)
  compareAtPrice Decimal?      @db.Decimal(12, 2)
  cost           Decimal?      @db.Decimal(12, 2)
  isFeatured     Boolean       @default(false)
  categoryId     String?
  supplierId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category          Category?          @relation(fields: [categoryId], references: [id])
  supplier          Supplier?          @relation(fields: [supplierId], references: [id])
  variants          ProductVariant[]
  attributes        ProductAttribute[]
  images            ProductImage[]
  inventory         Inventory[]
  orderItems        OrderItem[]
  cartItems         CartItem[]
  wishlists         Wishlist[]
  backInStockAlerts BackInStockAlert[]
  returnItems       ReturnItem[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([supplierId])
  @@index([createdAt])
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  sku       String   @unique
  name      String
  price     Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  Inventory[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  returnItems ReturnItem[]

  @@index([productId])
  @@index([sku])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductAttribute {
  id        String   @id @default(uuid())
  productId String
  name      String
  value     String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Inventory {
  id               String  @id @default(uuid())
  productId        String
  variantId        String?
  quantity         Int     @default(0)
  reservedQuantity Int     @default(0)
  lowStockThreshold Int?
  updatedAt        DateTime @updatedAt

  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant  ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([productId, variantId])
  @@index([productId])
  @@index([variantId])
}

model Cart {
  id        String   @id @default(uuid())
  userId    String?  @unique
  sessionId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  userId          String?
  customerEmail   String
  customerPhone   String?
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(12, 2)
  taxAmount       Decimal     @db.Decimal(12, 2) @default(0)
  shippingAmount  Decimal     @db.Decimal(12, 2) @default(0)
  discountAmount  Decimal     @db.Decimal(12, 2) @default(0)
  total           Decimal     @db.Decimal(12, 2)
  channel         OrderChannel @default(WEB)
  reservationExpiresAt DateTime?
  couponCode      String?
  paymentProvider String?
  shippingAddress Json?
  billingAddress  Json?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user           User?                @relation(fields: [userId], references: [id])
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  payments       Payment[]
  refunds        Refund[]
  invoice        Invoice?
  receipt        Receipt?
  returns        ReturnRequest[]
  exchangeFor    ReturnRequest?       @relation("ExchangeOrder")

  @@index([userId])
  @@index([status])
  @@index([customerPhone])
  @@index([channel])
  @@index([couponCode])
  @@index([reservationExpiresAt])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  variantId String?
  name      String
  sku       String
  price     Decimal  @db.Decimal(12, 2)
  quantity  Int
  createdAt DateTime @default(now())

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Payment {
  id                    String          @id @default(uuid())
  orderId               String
  provider              PaymentProvider
  providerTransactionId String?
  checkoutSessionId     String?
  idempotencyKey        String?         @unique
  amount                Decimal         @db.Decimal(12, 2)
  currency              String          @default("USD")
  status                PaymentStatus   @default(PENDING)
  metadata              Json?
  providerMetadata      Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@index([orderId])
  @@index([status])
  @@index([checkoutSessionId])
  @@index([createdAt])
  @@index([idempotencyKey])
}

model Refund {
  id              String        @id @default(uuid())
  orderId         String
  paymentId       String?
  returnRequestId String?
  providerRefundId String?
  amount          Decimal       @db.Decimal(12, 2)
  reason          String
  status          RefundStatus  @default(PENDING)
  requestedById   String?
  approvedById    String?
  providerMetadata Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment       Payment?       @relation(fields: [paymentId], references: [id])
  returnRequest ReturnRequest? @relation(fields: [returnRequestId], references: [id])

  @@index([orderId])
  @@index([paymentId])
  @@index([returnRequestId])
  @@index([providerRefundId])
  @@index([status])
  @@index([requestedById])
  @@index([approvedById])
}

model Receipt {
  id        String   @id @default(uuid())
  orderId   String   @unique
  number    String
  url       String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([number])
}

model Invoice {
  id                  String        @id @default(uuid())
  orderId             String        @unique
  documentType        String        @default("01")
  accessKey           String        @unique
  authorizationNumber String?
  status              InvoiceStatus @default(DRAFT)
  xmlContent          String?       @db.Text
  pdfUrl              String?
  sriResponse         Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([accessKey])
  @@index([status])
  @@index([createdAt])
}

model InvoiceSequence {
  id                String   @id @default(uuid())
  documentType      String
  establishmentCode String   @default("001")
  emissionPointCode String   @default("001")
  currentNumber     Int      @default(0)
  startNumber       Int
  endNumber         Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([documentType, establishmentCode, emissionPointCode])
}

model Promotion {
  id        String        @id @default(uuid())
  name      String
  type      PromotionType
  value     Decimal?      @db.Decimal(12, 2)
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  coupons       Coupon[]
  discountRules DiscountRule[]

  @@index([type])
  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  promotionId String
  usageLimit  Int?
  usageCount  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([promotionId])
}

model DiscountRule {
  id                   String  @id @default(uuid())
  promotionId          String
  minimumQuantity      Int?
  minimumAmount        Decimal? @db.Decimal(12, 2)
  applicableProductId  String?
  applicableCategoryId String?
  createdAt            DateTime @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model BackInStockAlert {
  id         String   @id @default(uuid())
  productId  String
  email      String
  isNotified Boolean  @default(false)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([email])
  @@index([createdAt])
}

model AuditLog {
  id               String   @id @default(uuid())
  actorId          String?
  actorClerkUserId String?
  resource         String
  action           String
  resourceId       String?
  diff             Json?
  metadata         Json?
  createdAt        DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([actorClerkUserId])
  @@index([resource])
  @@index([action])
  @@index([createdAt])
}

model Address {
  id            String   @id @default(uuid())
  userId        String?
  label         String?
  recipientName String
  street        String
  city          String
  state         String?
  country       String   @default("Ecuador")
  zipCode       String?
  phone         String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Conversation {
  id              String             @id @default(uuid())
  userId          String?
  customerPhone   String
  customerName    String?
  status          ConversationStatus @default(OPEN)
  assignedAgentId String?
  source          String             @default("whatsapp")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user     User?     @relation(fields: [userId], references: [id])
  messages Message[]

  @@index([userId])
  @@index([customerPhone])
  @@index([status])
  @@index([createdAt])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  direction      String
  content        String
  mediaUrl       String?
  status         String?
  senderType     String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  rucOrId       String?
  contactName   String?
  email         String?
  phone         String?
  address       String?
  paymentTerms  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products  Product[]
  expenses  Expense[]

  @@index([name])
  @@index([isActive])
  @@index([createdAt])
}

model Income {
  id              String       @id @default(uuid())
  source          IncomeSource
  amount          Decimal      @db.Decimal(12, 2)
  date            DateTime     @default(now())
  relatedOrderId  String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([source])
  @@index([date])
  @@index([createdAt])
}

model Expense {
  id          String        @id @default(uuid())
  categoryId  String?
  supplierId  String?
  amount      Decimal       @db.Decimal(12, 2)
  date        DateTime      @default(now())
  status      ExpenseStatus @default(PENDING)
  description String?
  attachments Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category ExpenseCategory? @relation(fields: [categoryId], references: [id])
  supplier Supplier?        @relation(fields: [supplierId], references: [id])

  @@index([categoryId])
  @@index([supplierId])
  @@index([status])
  @@index([date])
  @@index([createdAt])
}

model ExpenseCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses Expense[]

  @@index([name])
}

model ReturnRequest {
  id               String        @id @default(uuid())
  orderId          String
  userId           String?
  status           ReturnStatus  @default(REQUESTED)
  reason           String
  refundMethod     RefundMethod?
  returnWindowDays Int           @default(30)
  inspectedAt      DateTime?
  resolvedAt       DateTime?
  closedAt         DateTime?
  approvedById     String?
  rejectedById     String?
  creditNoteId     String?       @unique
  exchangeOrderId  String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  order         Order        @relation(fields: [orderId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])
  items         ReturnItem[]
  creditNote    CreditNote?  @relation(fields: [creditNoteId], references: [id])
  refunds       Refund[]
  exchangeOrder Order?       @relation("ExchangeOrder", fields: [exchangeOrderId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([exchangeOrderId])
}

model ReturnItem {
  id               String              @id @default(uuid())
  returnRequestId  String
  productId        String
  productVariantId String?
  quantity         Int
  condition        ReturnItemCondition?
  refundValue      Decimal?            @db.Decimal(12, 2)
  createdAt        DateTime            @default(now())

  returnRequest ReturnRequest     @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  product       Product           @relation(fields: [productId], references: [id])
  variant       ProductVariant?   @relation(fields: [productVariantId], references: [id])

  @@index([returnRequestId])
  @@index([productId])
  @@index([productVariantId])
}

model CreditNote {
  id                     String           @id @default(uuid())
  accessKey              String           @unique
  parentInvoiceAccessKey String?
  authorizationNumber    String?
  status                 CreditNoteStatus @default(DRAFT)
  xmlContent             String?          @db.Text
  signedXml              String?          @db.Text
  sriResponse            Json?
  totalAmount            Decimal          @db.Decimal(12, 2)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  returnRequest ReturnRequest?

  @@index([accessKey])
  @@index([parentInvoiceAccessKey])
  @@index([status])
  @@index([createdAt])
}

model StoreCredit {
  id        String    @id @default(uuid())
  userId    String
  balance   Decimal   @db.Decimal(12, 2) @default(0)
  currency  String    @default("USD")
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
