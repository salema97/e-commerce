{
  "name": "@repo/shared-utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared utility functions, helpers, and Zod schemas",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'No lint configured'",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@repo/shared-config": "workspace:^",
    "@repo/shared-types": "workspace:^",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
